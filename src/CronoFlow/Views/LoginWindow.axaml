<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CronoFlow.ViewModels"
        x:Class="CronoFlow.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="CronoFlow — Login"
        Width="420" Height="520"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" Background="#03A9F4" Padding="32,28">
            <StackPanel Spacing="4">
                <TextBlock Text="CronoFlow" FontSize="28" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Cronoanálise Corporativa" FontSize="13" Foreground="#E1F5FE"/>
            </StackPanel>
        </Border>

        <!-- Form -->
        <StackPanel Grid.Row="1" Margin="40,32" Spacing="16">
            <TextBlock Text="Entrar na sua conta" FontSize="18" FontWeight="SemiBold" Foreground="#263238"/>

            <StackPanel Spacing="6">
                <TextBlock Text="Usuário" FontSize="12" Foreground="#78909C"/>
                <TextBox Text="{Binding Username}" PlaceholderText="Digite seu usuário"
                         Height="40" CornerRadius="6"/>
            </StackPanel>

            <StackPanel Spacing="6">
                <TextBlock Text="Senha" FontSize="12" Foreground="#78909C"/>
                <TextBox Text="{Binding Password}" PasswordChar="●" PlaceholderText="Digite sua senha"
                         Height="40" CornerRadius="6"/>
            </StackPanel>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#E53935" FontSize="12"
                       IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <Button Content="Entrar" Command="{Binding LoginCommand}"
                    Height="44" CornerRadius="6"
                    Background="#03A9F4" Foreground="White"
                    HorizontalAlignment="Stretch" FontWeight="SemiBold"
                    Margin="0,8,0,0"/>

            <Border Background="#ECEFF1" CornerRadius="8" Padding="14" Margin="0,12,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Contas de demonstração:" FontSize="11" FontWeight="SemiBold" Foreground="#546E7A"/>
                    <TextBlock Text="Gerente: gerente / gerente123" FontSize="11" Foreground="#78909C"/>
                    <TextBlock Text="Funcionário: joao / joao123" FontSize="11" Foreground="#78909C"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>
